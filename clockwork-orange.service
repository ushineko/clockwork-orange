[Unit]
Description=Clockwork Orange - Wallpaper Service
After=graphical-session.target

[Service]
Type=simple
Environment=DISPLAY=:0
# Uses system Python 3 - ensure PyYAML is installed system-wide
# For conda/virtual environments, update the path to your Python interpreter
# -u keeps stdout unbuffered so journald timestamps reflect real cycle timing
# (block buffering otherwise flushes ~an hour of debug lines at once).
ExecStart=/usr/bin/python3 -u /home/nverenin/git/clockwork-orange/clockwork-orange.py --service
Restart=always
RestartSec=10

[Install]
WantedBy=default.target
